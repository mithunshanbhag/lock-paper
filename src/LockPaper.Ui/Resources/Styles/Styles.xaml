<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Thickness x:Key="ScreenPadding">24</Thickness>

    <Style x:Key="DeviceScreenStyle"
           TargetType="Border">
        <Setter Property="Padding"
                Value="22,28" />
        <Setter Property="Stroke"
                Value="{StaticResource ScreenFrameColor}" />
        <Setter Property="StrokeThickness"
                Value="12" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 36" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#2E2D4B"
                        Opacity="0.28"
                        Radius="28"
                        Offset="0,16" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ConnectedAppTitleLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                 Value="36" />
        <Setter Property="FontAttributes"
                 Value="Bold" />
        <Setter Property="TextColor"
                 Value="{StaticResource TitleTextColor}" />
    </Style>

    <Style x:Key="DisconnectedAppTitleLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="36" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="TextColor"
                Value="{StaticResource DarkTitleTextColor}" />
    </Style>

    <Style x:Key="StatusIconButtonStyle"
           TargetType="Button">
        <Setter Property="WidthRequest"
                Value="40" />
        <Setter Property="HeightRequest"
                Value="40" />
        <Setter Property="CornerRadius"
                Value="20" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="FontSize"
                Value="18" />
        <Setter Property="BackgroundColor"
                Value="{StaticResource SuccessSurfaceColor}" />
        <Setter Property="TextColor"
                Value="{StaticResource SuccessTextColor}" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource SuccessTextColor}"
                        Opacity="0.18"
                        Radius="18"
                        Offset="0,10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryActionButtonStyle"
           TargetType="Button">
        <Setter Property="HeightRequest"
                Value="56" />
        <Setter Property="CornerRadius"
                Value="16" />
        <Setter Property="Background"
                Value="{StaticResource PrimaryActionBackgroundBrush}" />
        <Setter Property="TextColor"
                Value="White" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource PrimaryActionPressedColor}"
                        Opacity="0.24"
                        Radius="20"
                        Offset="0,10" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity"
                                    Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="BaseCardStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource CardBackgroundColor}" />
        <Setter Property="Padding"
                Value="16" />
        <Setter Property="Stroke"
                Value="{StaticResource CardBorderColor}" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 18" />
        <Setter Property="StrokeThickness"
                Value="1" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#141E38"
                        Opacity="0.08"
                        Radius="16"
                        Offset="0,8" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource BaseCardStyle}" />

    <Style x:Key="HeroStatusCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource BaseCardStyle}">
        <Setter Property="Padding"
                Value="16,16,18,18" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 20" />
    </Style>

    <Style x:Key="AccountChipBorderStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="#2DFFFFFF" />
        <Setter Property="StrokeThickness"
                Value="0" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 999" />
    </Style>

    <Style x:Key="AccountChipLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="TextColor"
                Value="{StaticResource TitleTextColor}" />
    </Style>

    <Style x:Key="DisplaySummaryGroupStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="#F7F9FD" />
        <Setter Property="Padding"
                Value="12" />
        <Setter Property="Stroke"
                Value="{StaticResource CardBorderColor}" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness"
                Value="1" />
    </Style>

    <Style x:Key="DisplayStageStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="#F7F9FD" />
        <Setter Property="Padding"
                Value="16" />
        <Setter Property="Stroke"
                Value="{StaticResource CardBorderColor}" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 18" />
        <Setter Property="StrokeThickness"
                Value="1" />
    </Style>

    <Style x:Key="DisplayPreviewCardStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="White" />
        <Setter Property="Padding"
                Value="12" />
        <Setter Property="Stroke"
                Value="{StaticResource CardBorderColor}" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness"
                Value="1" />
    </Style>

    <Style x:Key="PlaceholderCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource BaseCardStyle}" />

    <Style x:Key="SectionLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="CharacterSpacing"
                Value="1.5" />
        <Setter Property="TextTransform"
                Value="Uppercase" />
        <Setter Property="TextColor"
                Value="{StaticResource MutedTextColor}" />
    </Style>

    <Style x:Key="DisconnectedFeedbackLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="LineHeight"
                Value="1.4" />
        <Setter Property="TextColor"
                Value="{StaticResource MutedTextColor}" />
    </Style>

    <Style x:Key="ConnectedFeedbackLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="LineHeight"
                Value="1.4" />
        <Setter Property="TextColor"
                 Value="{StaticResource ScreenSupportTextColor}" />
    </Style>

    <Style x:Key="RefreshFabButtonStyle"
           TargetType="Button">
        <Setter Property="WidthRequest"
                Value="44" />
        <Setter Property="HeightRequest"
                Value="44" />
        <Setter Property="CornerRadius"
                Value="22" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="FontSize"
                Value="24" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="Background"
                Value="{StaticResource PrimaryActionBackgroundBrush}" />
        <Setter Property="TextColor"
                Value="White" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource PrimaryActionPressedColor}"
                        Opacity="0.22"
                        Radius="18"
                        Offset="0,10" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity"
                                    Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="CardValueLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="17" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="LineHeight"
                Value="1.3" />
        <Setter Property="TextColor"
                Value="{StaticResource CardTextColor}" />
    </Style>

    <Style x:Key="CardSummaryLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="LineHeight"
                Value="1.4" />
        <Setter Property="TextColor"
                 Value="{StaticResource MutedTextColor}" />
    </Style>

    <Style x:Key="ActivityPrimaryLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="20" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="LineHeight"
                Value="1.2" />
        <Setter Property="TextColor"
                Value="{StaticResource CardTextColor}" />
    </Style>

    <Style x:Key="ActivityDetailLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="LineHeight"
                Value="1.35" />
        <Setter Property="TextColor"
                Value="{StaticResource MutedTextColor}" />
    </Style>

    <Style x:Key="StatusBadgeBorderStyle"
           TargetType="Border">
        <Setter Property="Background"
                Value="#EAF0FF" />
        <Setter Property="Padding"
                Value="12,6" />
        <Setter Property="StrokeThickness"
                Value="0" />
        <Setter Property="StrokeShape"
                Value="RoundRectangle 999" />
        <Setter Property="VerticalOptions"
                Value="Start" />
    </Style>

    <Style x:Key="StatusBadgeLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="TextColor"
                Value="{StaticResource PrimaryActionPressedColor}" />
    </Style>

    <Style x:Key="DisplayPreviewResolutionLabelStyle"
           TargetType="Label">
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="FontAttributes"
                Value="Bold" />
        <Setter Property="LineHeight"
                Value="1.15" />
        <Setter Property="TextColor"
                Value="White" />
        <Setter Property="HorizontalTextAlignment"
                Value="Center" />
        <Setter Property="VerticalTextAlignment"
                Value="Center" />
        <Setter Property="LineBreakMode"
                Value="WordWrap" />
    </Style>

    <Style x:Key="PlaceholderPickerStyle"
           TargetType="Picker">
        <Setter Property="BackgroundColor"
                Value="White" />
        <Setter Property="TextColor"
                Value="{StaticResource CardTextColor}" />
        <Setter Property="TitleColor"
                Value="{StaticResource MutedTextColor}" />
    </Style>
</ResourceDictionary>
