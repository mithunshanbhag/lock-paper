<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:LockPaper.Ui.Misc.Converters"
             xmlns:models="clr-namespace:LockPaper.Ui.Models"
             xmlns:pageModels="clr-namespace:LockPaper.Ui.PageModels"
             x:Class="LockPaper.Ui.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             Title="LockPaper"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.Resources>
        <converters:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="{StaticResource ScreenPadding}"
              HorizontalOptions="Center">
            <Border Style="{StaticResource DeviceScreenStyle}"
                    WidthRequest="360"
                    MinimumHeightRequest="760"
                    Background="{StaticResource DisconnectedScreenBackgroundBrush}"
                    IsVisible="{Binding ShowSignedOutLayout}">
                <VerticalStackLayout Spacing="18"
                                     VerticalOptions="Center">
                    <Label Text="LockPaper"
                           Style="{StaticResource DisconnectedAppTitleLabelStyle}"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Button Text="{Binding PrimaryActionText}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding PrimaryActionCommand}"
                            IsEnabled="{Binding IsPrimaryActionEnabled}" />

                    <Label Text="{Binding FeedbackText}"
                           Style="{StaticResource DisconnectedFeedbackLabelStyle}"
                           IsVisible="{Binding ShowFeedback}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource DeviceScreenStyle}"
                    WidthRequest="360"
                    MinimumHeightRequest="760"
                    Background="{StaticResource ConnectedScreenBackgroundBrush}"
                    IsVisible="{Binding ShowConnectedLayout}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <Label Text="LockPaper"
                               Style="{StaticResource ConnectedAppTitleLabelStyle}"
                               SemanticProperties.HeadingLevel="Level1" />

                        <Button Grid.Column="1"
                                Text="✓"
                                Style="{StaticResource StatusIconButtonStyle}"
                                IsVisible="{Binding IsLogoutVisible}"
                                 Clicked="OnLogoutClicked"
                                 SemanticProperties.Description="Open log out confirmation dialog" />
                    </Grid>

                    <Border Style="{StaticResource AccountChipBorderStyle}"
                            HorizontalOptions="Start"
                            Padding="12,8">
                        <Label Text="{Binding AccountStatusText}"
                               Style="{StaticResource AccountChipLabelStyle}"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                    </Border>

                    <Label Text="{Binding FeedbackText}"
                           Style="{StaticResource ConnectedFeedbackLabelStyle}"
                           IsVisible="{Binding ShowFeedback}" />

                    <Border Style="{StaticResource HeroStatusCardStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding DisplaySummaryHeading}"
                                           Style="{StaticResource SectionLabelStyle}" />
                                    <Label Text="{Binding DisplaySummaryMetaText}"
                                           Style="{StaticResource CardSummaryLabelStyle}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="↻"
                                        Style="{StaticResource RefreshFabButtonStyle}"
                                        Command="{Binding PrimaryActionCommand}"
                                        IsEnabled="{Binding IsPrimaryActionEnabled}"
                                        SemanticProperties.Description="{Binding PrimaryActionText}" />
                            </Grid>

                            <Label Text="{Binding DisplaySummaryText}"
                                   Style="{StaticResource CardSummaryLabelStyle}"
                                   IsVisible="{Binding ShowDisplaySummaryText}" />

                            <Border Style="{StaticResource DisplayStageStyle}"
                                    IsVisible="{Binding ShowDisplayPreviewStage}">
                                <FlexLayout BindableLayout.ItemsSource="{Binding DisplayPreviews}"
                                            Wrap="Wrap"
                                            Direction="Row"
                                            AlignItems="Start"
                                            JustifyContent="Center">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:DisplayPreview">
                                            <Border Background="{Binding PreviewColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 24"
                                                    WidthRequest="{Binding PreviewWidth}"
                                                    HeightRequest="{Binding PreviewHeight}"
                                                    Margin="6"
                                                    Padding="0"
                                                    HorizontalOptions="Center">
                                                <Grid>
                                                    <Image Source="{Binding WallpaperThumbnailPath}"
                                                           Aspect="AspectFill"
                                                           IsVisible="{Binding ShowWallpaperThumbnail}" />
                                                    <BoxView Color="#66000000"
                                                             IsVisible="{Binding ShowWallpaperThumbnail}" />
                                                    <Grid Padding="8">
                                                        <Label Text="{Binding ResolutionText}"
                                                               Style="{StaticResource DisplayPreviewResolutionLabelStyle}"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Last update"
                                           Style="{StaticResource SectionLabelStyle}" />
                                    <Label Text="{Binding LastAttemptText}"
                                           Style="{StaticResource ActivityPrimaryLabelStyle}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadgeBorderStyle}">
                                    <Label Text="{Binding LastAttemptStatusText}"
                                           Style="{StaticResource StatusBadgeLabelStyle}" />
                                </Border>
                            </Grid>

                            <Label Text="{Binding LastAttemptDetailText}"
                                   Style="{StaticResource ActivityDetailLabelStyle}"
                                   IsVisible="{Binding ShowLastAttemptDetailText}" />

                            <BoxView HeightRequest="1"
                                     Color="{StaticResource CardBorderColor}" />

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Next"
                                           Style="{StaticResource SectionLabelStyle}" />
                                    <Label Text="{Binding NextAttemptText}"
                                           Style="{StaticResource ActivityPrimaryLabelStyle}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadgeBorderStyle}">
                                    <Label Text="{Binding NextAttemptStatusText}"
                                           Style="{StaticResource StatusBadgeLabelStyle}" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
