<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:LockPaper.Ui.PageModels"
             x:Class="LockPaper.Ui.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             Title="LockPaper"
             Shell.NavBarIsVisible="False"
              BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <Grid Padding="{StaticResource ScreenPadding}"
              HorizontalOptions="Center">
            <Border Style="{StaticResource DeviceScreenStyle}"
                    WidthRequest="360"
                    MinimumHeightRequest="760"
                    Background="{StaticResource DisconnectedScreenBackgroundBrush}"
                    IsVisible="{Binding ShowSignedOutLayout}">
                <VerticalStackLayout Spacing="18"
                                     VerticalOptions="Center">
                    <Label Text="LockPaper"
                           Style="{StaticResource DisconnectedAppTitleLabelStyle}"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Button Text="{Binding PrimaryActionText}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding PrimaryActionCommand}"
                            IsEnabled="{Binding IsPrimaryActionEnabled}" />

                    <Label Text="{Binding FeedbackText}"
                           Style="{StaticResource DisconnectedFeedbackLabelStyle}"
                           IsVisible="{Binding ShowFeedback}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource DeviceScreenStyle}"
                    WidthRequest="360"
                    MinimumHeightRequest="760"
                    Background="{StaticResource ConnectedScreenBackgroundBrush}"
                    IsVisible="{Binding ShowConnectedLayout}">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <Label Text="LockPaper"
                               Style="{StaticResource ConnectedAppTitleLabelStyle}"
                               SemanticProperties.HeadingLevel="Level1" />

                        <Button Grid.Column="1"
                                Text="✓"
                                Style="{StaticResource StatusIconButtonStyle}"
                                IsVisible="{Binding IsLogoutVisible}"
                                Clicked="OnLogoutClicked"
                                SemanticProperties.Description="Log out" />
                    </Grid>

                    <Button Text="{Binding PrimaryActionText}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding PrimaryActionCommand}"
                            IsEnabled="{Binding IsPrimaryActionEnabled}" />

                    <Label Text="{Binding FeedbackText}"
                           Style="{StaticResource ConnectedFeedbackLabelStyle}"
                           IsVisible="{Binding ShowFeedback}" />

                    <Border Style="{StaticResource StatusCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding PrimaryStatusLabel}"
                                   Style="{StaticResource SectionLabelStyle}" />
                            <Label Text="{Binding PrimaryStatusText}"
                                   Style="{StaticResource CardValueLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource StatusCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding SecondaryStatusLabel}"
                                   Style="{StaticResource SectionLabelStyle}" />
                            <Label Text="{Binding SecondaryStatusText}"
                                   Style="{StaticResource CardValueLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
