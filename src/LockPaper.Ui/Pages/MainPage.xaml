<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:LockPaper.Ui.PageModels"
             x:Class="LockPaper.Ui.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             Title="LockPaper"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <Grid Padding="{StaticResource ScreenPadding}"
              MinimumHeightRequest="760"
              MaximumWidthRequest="408"
              HorizontalOptions="Center">
            <Border Style="{StaticResource DeviceScreenStyle}">
                <VerticalStackLayout Spacing="18"
                                     VerticalOptions="Center">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="LockPaper"
                                   Style="{StaticResource AppTitleLabelStyle}"
                                   SemanticProperties.HeadingLevel="Level1" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="✓"
                                Style="{StaticResource StatusIconButtonStyle}"
                                IsVisible="{Binding IsLogoutVisible}"
                                Clicked="OnLogoutClicked"
                                SemanticProperties.Description="Log out" />
                    </Grid>

                    <Button Text="{Binding PrimaryActionText}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding PrimaryActionCommand}"
                            IsEnabled="{Binding IsPrimaryActionEnabled}" />

                    <Border Style="{StaticResource NoticeCardStyle}"
                            IsVisible="{Binding ShowNotice}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding NoticeTitle}"
                                   Style="{StaticResource CardTitleLabelStyle}" />
                            <Label Text="{Binding NoticeMessage}"
                                   Style="{StaticResource CardBodyLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding ShowStatusSummary}">
                        <Border Grid.Column="0"
                                Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Microsoft account"
                                       Style="{StaticResource SectionLabelStyle}" />
                                <Label Text="{Binding AccountSummaryText}"
                                       Style="{StaticResource CardValueLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Session"
                                       Style="{StaticResource SectionLabelStyle}" />
                                <Label Text="{Binding ConnectionSummaryText}"
                                       Style="{StaticResource CardValueLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
